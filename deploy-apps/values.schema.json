{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "image": {
      "type": "object",
      "properties": {
        "repository": { "type": "string" },
        "pullPolicy": { "type": "string" },
        "tag": { "type": "string" }
      }
    },
    "imagePullSecrets": {
      "type": "array"
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "automount": { "type": "boolean" },
        "annotations": { "type": "object" },
        "name": { "type": "string" },
        "namespace": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean" },
        "rules": { "type": "array" },
        "useClusterRole": { "type": "boolean" }
      }
    },
    "gatewayApi": {
      "type": "object",
      "description": "Global Gateway API defaults",
      "properties": {
        "gatewayClassName": { "type": "string" },
        "clusterIssuer": { "type": "string" }
      }
    },
    "global": {
      "type": "object"
    },
    "apps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "enabled", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "enabled": { "type": "boolean" },
          "type": {
            "type": "string",
            "enum": ["deployment", "statefulset", "cronjob", "job"]
          },
          "strategy": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["RollingUpdate", "Recreate"]
              },
              "rollingUpdate": {
                "type": "object",
                "properties": {
                  "maxSurge": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "integer" }
                    ]
                  },
                  "maxUnavailable": {
                    "oneOf": [
                      { "type": "string" },
                      { "type": "integer" }
                    ]
                  }
                }
              }
            }
          },
          "terminationGracePeriodSeconds": {
            "type": "integer",
            "minimum": 0
          },
          "priorityClassName": {
            "type": "string"
          },
          "topologySpreadConstraints": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "lifecycle": {
            "type": "object",
            "properties": {
              "preStop": {
                "type": "object"
              },
              "postStart": {
                "type": "object"
              }
            }
          },
          "gatewayApi": {
            "type": "object",
            "description": "Gateway API (Envoy) configuration",
            "properties": {
              "enabled": { "type": "boolean" },
              "gatewayClassName": { "type": "string" },
              "clusterIssuer": { "type": "string" },
              "gateway": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "listeners": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "hostname": { "type": "string" },
                        "secretName": { "type": "string" },
                        "port": { "type": "integer" }
                      }
                    }
                  }
                }
              },
              "gatewayRef": {
                "type": "object",
                "description": "Reference to existing Gateway (when not creating one)",
                "properties": {
                  "name": { "type": "string" },
                  "namespace": { "type": "string" }
                }
              },
              "httpRoutes": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "listenerName": { "type": "string" },
                    "hostnames": { "type": "array", "items": { "type": "string" } },
                    "rules": { "type": "array" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
