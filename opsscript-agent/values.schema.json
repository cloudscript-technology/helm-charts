{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "opsscript-agent values",
  "type": "object",
  "properties": {
    "replicaCount": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1,
      "description": "The agent is a singleton; more than 1 replica duplicates collections",
      "default": 1
    },
    "image": {
      "type": "object",
      "properties": {
        "repository": {
          "type": "string",
          "default": "public.ecr.aws/a3g9d1z6/opsscript-agent"
        },
        "pullPolicy": {
          "type": "string",
          "enum": ["Always", "IfNotPresent", "Never"],
          "default": "IfNotPresent"
        },
        "tag": {
          "type": "string",
          "description": "Defaults to the chart appVersion",
          "default": ""
        }
      }
    },
    "imagePullSecrets": { "type": "array" },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "config": {
      "type": "object",
      "properties": {
        "agentServerUrl": {
          "type": "string",
          "format": "uri",
          "default": "https://agent.opsscript.io"
        },
        "agentId": {
          "type": "string",
          "description": "Agent ID generated by OpsScript; optional when provided via credentials.existingSecret"
        },
        "logLevel": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "default": "info"
        },
        "searchInterval": { "type": "integer", "minimum": 1, "default": 60 },
        "reloadIntervalSeconds": { "type": "integer", "minimum": 0, "default": 60 },
        "clusterName": {
          "type": "string",
          "description": "Cluster name (CLUSTER_NAME) used in the heartbeat and as the cluster name in the OpsScript inventory (agent >= v1.0.4); empty omits the variable and the agent autodetects"
        }
      }
    },
    "credentials": {
      "type": "object",
      "properties": {
        "existingSecret": {
          "type": "string",
          "description": "Name of an existing Secret with keys AGENT_TOKEN (required) and AGENT_ID (optional). Preferred over agentToken."
        },
        "agentToken": {
          "type": "string",
          "description": "Agent token; the chart creates the Secret. Avoid in GitOps repositories."
        }
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8081 }
      }
    },
    "terminationGracePeriodSeconds": {
      "type": "integer",
      "minimum": 1,
      "description": "Seconds Kubernetes waits after SIGTERM before SIGKILL; must exceed preStop sleep plus the agent cron drain window",
      "default": 60
    },
    "lifecycle": {
      "type": "object",
      "properties": {
        "preStop": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": true },
            "sleepSeconds": {
              "type": "integer",
              "minimum": 0,
              "description": "Native sleep lifecycle action (k8s >= 1.29); must be less than terminationGracePeriodSeconds",
              "default": 10
            }
          }
        }
      }
    },
    "livenessProbe": { "type": "object" },
    "readinessProbe": { "type": "object" },
    "webhooksServer": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean", "default": false },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8080 },
        "alertmanagerPath": { "type": "string", "default": "/webhooks/alertmanager" },
        "service": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": ["ClusterIP", "NodePort", "LoadBalancer"],
              "default": "ClusterIP"
            },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535, "default": 8080 },
            "annotations": { "type": "object" }
          }
        },
        "ingress": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "className": { "type": "string" },
            "annotations": { "type": "object" },
            "hostname": { "type": "string" },
            "path": { "type": "string", "default": "/" },
            "tls": { "type": "array" }
          }
        },
        "httpRoute": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean", "default": false },
            "annotations": { "type": "object" },
            "parentRefs": { "type": "array", "items": { "type": "object" } },
            "hostnames": { "type": "array", "items": { "type": "string" } },
            "path": { "type": "string", "default": "/" }
          }
        }
      }
    },
    "extraEnv": { "type": "array" },
    "extraEnvFrom": { "type": "array" },
    "serviceAccount": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "automount": { "type": "boolean", "default": true },
        "annotations": { "type": "object" },
        "name": { "type": "string" }
      }
    },
    "rbac": {
      "type": "object",
      "properties": {
        "create": { "type": "boolean", "default": true },
        "extraRules": { "type": "array", "items": { "type": "object" } }
      }
    },
    "podAnnotations": { "type": "object" },
    "podLabels": { "type": "object" },
    "podSecurityContext": { "type": "object" },
    "securityContext": { "type": "object" },
    "resources": { "type": "object" },
    "priorityClassName": { "type": "string" },
    "nodeSelector": { "type": "object" },
    "tolerations": { "type": "array" },
    "affinity": { "type": "object" }
  }
}
